{
  "name": "developer-toolbox",
  "displayName": "Developer Toolbox",
  "description": "All-in-one developer utilities — 18+ tools including API Tester, JSON Formatter, Color Palette, Regex Generator, JWT Decoder, SQL Playground, and more. All running directly inside VS Code.",
  "version": "1.0.0",
  "publisher": "PooranaSelvan",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/PooranaSelvan/developer-toolbox"
  },
  "bugs": {
    "url": "https://github.com/PooranaSelvan/developer-toolbox/issues"
  },
  "homepage": "https://github.com/PooranaSelvan/developer-toolbox#readme",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Testing",
    "Visualization",
    "Education"
  ],
  "keywords": [
    "developer tools",
    "json formatter",
    "api tester",
    "color palette",
    "regex",
    "jwt",
    "sql",
    "css gradient",
    "password generator",
    "sorting visualizer"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "developerToolbox.open",
        "title": "Open Developer Toolbox",
        "category": "Developer Toolbox",
        "icon": "$(tools)"
      },
      {
        "command": "developerToolbox.openTool",
        "title": "Open Specific Tool...",
        "category": "Developer Toolbox"
      },
      {
        "command": "developerToolbox.jsonFormatter",
        "title": "Open JSON Formatter",
        "category": "Developer Toolbox"
      },
      {
        "command": "developerToolbox.apiTester",
        "title": "Open API Tester",
        "category": "Developer Toolbox"
      },
      {
        "command": "developerToolbox.regexGenerator",
        "title": "Open Regex Generator",
        "category": "Developer Toolbox"
      },
      {
        "command": "developerToolbox.colorPalette",
        "title": "Open Color Palette",
        "category": "Developer Toolbox"
      },
      {
        "command": "developerToolbox.jwtDecoder",
        "title": "Open JWT Decoder",
        "category": "Developer Toolbox"
      },
      {
        "command": "developerToolbox.passwordGenerator",
        "title": "Open Password Generator",
        "category": "Developer Toolbox"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "developerToolbox.jsonFormatter",
          "when": "resourceLangId == json || resourceLangId == jsonc",
          "group": "developerToolbox"
        }
      ],
      "commandPalette": [
        {
          "command": "developerToolbox.open",
          "group": "developerToolbox"
        },
        {
          "command": "developerToolbox.openTool",
          "group": "developerToolbox"
        }
      ]
    },
    "keybindings": [
      {
        "command": "developerToolbox.open",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "developerToolbox",
          "title": "Developer Toolbox",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "developerToolbox": [
        {
          "type": "webview",
          "id": "developerToolbox.sidebarView",
          "name": "Quick Access",
          "visibility": "visible"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:webview && npm run build:extension",
    "build:webview": "vite build --config vite.webview.config.js",
    "build:extension": "node esbuild.config.cjs",
    "dev:webview": "vite build --config vite.webview.config.js --watch",
    "dev:extension": "node esbuild.config.cjs --watch",
    "dev": "concurrently \"npm run dev:webview\" \"npm run dev:extension\"",
    "lint": "eslint .",
    "package": "vsce package"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@lezer/highlight": "^1.2.3",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-ripples": "^2.2.1",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.96.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vscode/vsce": "^3.7.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.21"
  }
}
